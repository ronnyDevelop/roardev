---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Mi Portafolio">
  <section class="py-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Blog Técnico</h1>
    <p class="text-gray-600 mb-8 max-w-2xl">
      Artículos sobre desarrollo web, inteligencia artificial y otras tecnologías.
      Comparto tutoriales, guías y reflexiones sobre el mundo del desarrollo de software.
    </p>

    <div class="space-y-6">
      {sortedPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          url={`/blog/${post.slug}`}
          tags={post.data.tags}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500">No hay posts disponibles todavía.</p>
        <p class="text-gray-400 text-sm mt-2">Añade posts en src/content/blog/</p>
      </div>
    )}
  </section>
</BaseLayout>