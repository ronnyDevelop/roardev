---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mi Portafolio | Desarrollador Full Stack">
  <section class="text-center py-16">
    <div class="w-32 h-32 mx-auto mb-6 bg-primary-100 rounded-full flex items-center justify-center">
      <span class="text-4xl text-primary-600">👨‍💻</span>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 mb-4">
      Hola, soy <span class="text-primary-600">Tu Nombre</span>
    </h1>
    <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
      Desarrollador Full Stack e Inteligencia Artificial Generativa. Construyo aplicaciones web modernas y soluciones basadas en IA.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/projects" class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
        Ver proyectos
      </a>
      <a href="/about" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:border-primary-600 hover:text-primary-600 transition-colors">
        Sobre mí
      </a>
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Stack tecnológico</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {["JavaScript", "TypeScript", "React", "Node.js", "Python", "PostgreSQL", "Git", "AWS"].map((tech) => (
        <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
          <span class="text-gray-700 font-medium">{tech}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Últimos posts</h2>
    <p class="text-gray-600 mb-4">
      <a href="/blog" class="text-primary-600 hover:underline">Ver todos los posts →</a>
    </p>
  </section>
</BaseLayout>