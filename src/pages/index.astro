---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mi Portafolio | Desarrollador Full Stack">
  <section class="text-center py-16">
    <div class="w-32 h-32 mx-auto mb-6 rounded-full overflow-hidden border-4 border-purple-400 shadow-lg">
      <img src="/avatar.png" alt="Mi avatar" class="w-full h-full object-cover" />
    </div>
    <h1 class="text-4xl font-bold text-white mb-4">
      Hola, soy <span class="text-purple-400">Ronny</span>
    </h1>
    <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
      Desarrollador Full Stack e Inteligencia Artificial Generativa. Construyo aplicaciones web modernas y soluciones basadas en IA.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/projects" class="px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
        Ver proyectos
      </a>
      <a href="/about" class="px-6 py-3 border border-purple-400 text-purple-300 rounded-lg hover:bg-purple-900/30 transition-colors">
        Sobre mí
      </a>
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-bold text-white mb-6">Stack tecnológico</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {["JavaScript", "TypeScript", "React", "Node.js", "Python", "PostgreSQL", "Git", "AWS"].map((tech) => (
        <div class="bg-white/10 border border-purple-500/30 rounded-lg p-4 text-center backdrop-blur-sm">
          <span class="text-gray-200 font-medium">{tech}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-bold text-white mb-6">Últimos posts</h2>
    <p class="text-gray-400 mb-4">
      <a href="/blog" class="text-purple-400 hover:underline">Ver todos los posts →</a>
    </p>
  </section>
</BaseLayout>