---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Mi portafolio personal" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <header class="bg-black/20 backdrop-blur-md border-b border-purple-500/30 sticky top-0 z-50">
      <nav class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-purple-400">RoArDev</a>
        <ul class="flex gap-6">
          <li><a href="/" class="text-gray-300 hover:text-purple-400 transition-colors">Inicio</a></li>
          <li><a href="/about" class="text-gray-300 hover:text-purple-400 transition-colors">Sobre mí</a></li>
          <li><a href="/projects" class="text-gray-300 hover:text-purple-400 transition-colors">Proyectos</a></li>
          <li><a href="/blog" class="text-gray-300 hover:text-purple-400 transition-colors">Blog</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 max-w-4xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <footer class="bg-black/20 backdrop-blur-md border-t border-purple-500/30 py-6 mt-12">
      <div class="max-w-4xl mx-auto px-4 text-center text-gray-400">
        <p>&copy; {new Date().getFullYear()} Mi Portafolio. Todos los derechos reservados.</p>
        <div class="flex justify-center gap-4 mt-4">
          <a href="https://github.com/ronnydevelop" target="_blank" class="text-gray-500 hover:text-purple-400">
            GitHub
          </a>
          <a href="#" target="_blank" class="text-gray-500 hover:text-purple-400">
            LinkedIn
          </a>
          <a href="#" target="_blank" class="text-gray-500 hover:text-purple-400">
            Twitter
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>