---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  url: string;
  tags?: string[];
}

const { title, description, pubDate, url, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="bg-white/10 rounded-lg border border-purple-500/30 p-6 hover:border-purple-400 hover:bg-white/20 transition-all backdrop-blur-sm">
  <a href={url} class="block">
    <h3 class="text-xl font-semibold text-white mb-2 hover:text-purple-400 transition-colors">
      {title}
    </h3>
    <p class="text-gray-300 mb-3">{description}</p>
    <div class="flex items-center justify-between">
      <time class="text-sm text-gray-500">{formattedDate}</time>
      {tags && (
        <div class="flex gap-2">
          {tags.slice(0, 2).map((tag) => (
            <span class="text-xs text-purple-400">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>