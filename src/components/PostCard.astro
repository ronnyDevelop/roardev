---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  url: string;
  tags?: string[];
}

const { title, description, pubDate, url, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="bg-white rounded-lg border border-gray-200 p-6 hover:border-primary-300 hover:shadow-lg transition-all">
  <a href={url} class="block">
    <h3 class="text-xl font-semibold text-gray-900 mb-2 hover:text-primary-600 transition-colors">
      {title}
    </h3>
    <p class="text-gray-600 mb-3">{description}</p>
    <div class="flex items-center justify-between">
      <time class="text-sm text-gray-500">{formattedDate}</time>
      {tags && (
        <div class="flex gap-2">
          {tags.slice(0, 2).map((tag) => (
            <span class="text-xs text-gray-400">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>