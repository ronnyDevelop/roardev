---
interface Props {
  title: string;
  description: string;
  tags: string[];
  url?: string;
  github?: string;
}

const { title, description, tags, url, github } = Astro.props;
---

<div class="bg-white rounded-lg border border-gray-200 p-6 hover:border-primary-300 hover:shadow-lg transition-all">
  <h3 class="text-xl font-semibold text-gray-900 mb-2">{title}</h3>
  <p class="text-gray-600 mb-4">{description}</p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map((tag) => (
      <span class="px-2 py-1 text-xs bg-primary-50 text-primary-700 rounded-full">
        {tag}
      </span>
    ))}
  </div>
  <div class="flex gap-4">
    {url && (
      <a href={url} target="_blank" class="text-primary-600 hover:text-primary-700 font-medium">
        Ver proyecto →
      </a>
    )}
    {github && (
      <a href={github} target="_blank" class="text-gray-500 hover:text-gray-700">
        GitHub →
      </a>
    )}
  </div>
</div>